{
  "name": "pos-transaction-engine",
  "version": "1.0.0",
  "description": "Production-grade POS backend demonstrating pessimistic locking, idempotency, async audit logging, and rate limiting",
  "license": "ISC",
  "author": "Vijay Singh",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm src/app.ts",
    "start": "node dist/app.js",
    "migrate": "node --loader ts-node/esm src/db/migrate.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
